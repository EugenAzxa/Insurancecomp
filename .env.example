# QuietWorld — environment variables
# Copy this file to .env.local and fill in real values for local dev.
# In production, set these in the Vercel project's Environment Variables.

# Stripe secret key (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx

# Recurring Price ID for the $25/mo QuietWorld subscription
# (Stripe → Products → your product → Pricing → API ID, looks like price_xxx).
# If omitted, the checkout route falls back to an inline $25 CAD/mo price.
STRIPE_PRICE_ID=price_xxx

# Canonical site URL, used for Stripe success/cancel redirects.
# Locally this can be http://localhost:3000; in prod set:
#   NEXT_PUBLIC_SITE_URL=https://finallypeace.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (waitlist signup storage) ──
# From your Supabase project: Settings → API.
#   SUPABASE_URL                = Project URL (https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY   = service_role secret (NEVER expose to the client;
#                                 it's only read in the /api/waitlist server route)
# If both are unset, the signup form still works but data isn't persisted.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
